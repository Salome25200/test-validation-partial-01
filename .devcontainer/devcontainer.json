{
  "name": "Java 11 - Spring Boot - JUnit 5",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-boot-dashboard",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-spring-boot",
        "vscjava.vscode-java-test",
        "vscjava.vscode-maven"
      ],
      "settings": {
        "extensions.ignoreRecommendations": true,
        "extensions.autoCheckUpdates": false,
        "extensions.autoUpdate": false,
        "extensions.showRecommendationsOnlyOnDemand": true,
        "workbench.settings.enableNaturalLanguageSearch": false,
        "github.copilot.enable": false,
        "github.copilot.editor.enableAutoCompletions": false,
        "github.copilot.chat.enable": false,
        "github.copilot.inlineSuggest.enable": false,
        "github.copilot.nextEditSuggestions.enabled": false,
        "github.copilot.advanced": {},
        "extensionsGallery": {
          "serviceUrl": "https://127.0.0.1:9999",
          "itemUrl": "https://127.0.0.1:9999"
        }
      }
    }
  },
  "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh ${containerWorkspaceFolder}",
  "remoteUser": "vscode"
}
